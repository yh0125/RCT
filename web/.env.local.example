# Supabase 配置（从 Supabase Dashboard -> Settings -> API 获取）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 站点 URL（用于生成患者二维码）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 目标入组人数
NEXT_PUBLIC_TARGET_ENROLLMENT=100

# 管理后台 Basic Auth（访问 /admin 需要）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
ADMIN_SESSION_TOKEN=replace-with-a-random-long-string

# 入组邮件通知（可选，配置后可在后台开启）
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=RCT-AI <notify@yourdomain.com>

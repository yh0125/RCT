# Supabase 配置（从 Supabase Dashboard -> Settings -> API 获取）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 站点 URL（npm run build 时写入前端；改后须重新 build + 部署）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 设为 1 时：患者二维码始终用「当前浏览器地址栏的 origin」，不读上面变量（适合备案期用 http://IP 打开后台）
# NEXT_PUBLIC_PATIENT_QR_USE_ORIGIN=1

# 可选：Next standalone 监听地址，生产建议不设（PM2 默认 0.0.0.0）
# 勿在 .env.local 里设置名为 HOSTNAME 的变量（Linux 系统变量易冲突）
# APP_BIND_HOST=0.0.0.0

# 目标入组人数
NEXT_PUBLIC_TARGET_ENROLLMENT=100

# 管理后台登录（/admin-login）；中间件校验 Cookie admin_session
# 生产环境用 PM2 时：web/ecosystem.config.cjs 会读取本文件并注入进程，改密码后需重启 PM2
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
# 可选：单独指定会话 Cookie 值；不填则与 ADMIN_PASSWORD 相同（建议生产设长随机串）
ADMIN_SESSION_TOKEN=replace-with-a-random-long-string

# 仅用 http://公网IP 测试时：设为 1 可强制登录 Cookie 不带 Secure（否则浏览器不保存）。
# 正式用 https://域名 后请删除本行或改为 0
# ADMIN_COOKIE_INSECURE_HTTP=1

# 入组邮件通知（可选，配置后可在后台开启）
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=RCT-AI <notify@yourdomain.com>

# ─── AI 解读 / 配图（后台「生成解读」等，必填，否则报「未配置 AI API」）────────
# 须为 OpenAI 兼容的 Chat Completions 地址（POST JSON，Bearer 鉴权）
# 示例（按你实际供应商改）：https://api.openai.com/v1/chat/completions
# t8star：对话与文生图同域名，仅路径不同（images 由代码从 chat URL 推导，一般无需另设）
AI_API_URL=https://ai.t8star.cn/v1/chat/completions
AI_API_KEY=sk-或供应商提供的-key
# 可选：模型名（默认已与 t8star 常用配置一致，见 route.ts）
# AI_MODEL=gemini-3.1-flash-lite-preview-thinking-high
# AI_PROMPT_MODEL=gemini-3.1-flash-lite-preview-thinking-high
# AI_IMAGE_MODEL=gemini-3.1-flash-image-preview-4k
# AI_IMAGE_REFERENCE_URL=
#
# 若网关提示「不支持 /v1/images/generations」或 503 invalid_request：
# - 向供应商确认「文生图」可用的模型与路径；将 AI_IMAGE_MODEL 改为他们支持的图像模型。
# - 若图像与对话不在同一域名/路径，可单独指定完整 POST 地址：
# AI_IMAGE_GENERATIONS_URL=https://你的网关/v1/images/generations
# - 暂时只要文字解读、不要配图时设为 0：
# AI_ENABLE_IMAGE_GENERATION=0
